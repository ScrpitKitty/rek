# Allow Python scripts
!*.py
# Allow wordlists (only .txt files — prevents scan artifact files like IP-named outputs)
!global_wordlist.txt
!wordlists/
!wordlists/*.txt
wordlists/[0-9]*
# Explicitly ignore specific files and directories
results/
venv/
pipelines/
tools/
http_results.csv
__pycache__/
*.pyc
*.log
.env
*.bak
*.swp
*.swo
.DS_Store
.vscode/
.idea/
*.iml
*.csv
*.png
*.jpg
*.jpeg
*.gif